# ================================
# GROQ API KEYS (get free at console.groq.com)
# ================================
GROQ_API_KEY_PRIMARY=gsk_your_primary_key_here
GROQ_API_KEY_FALLBACK=gsk_your_fallback_key_here
GROQ_API_KEY_3=gsk_your_third_key_here
GROQ_API_KEY_4=gsk_your_fourth_key_here

# ================================
# MODELS
# ================================
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# ================================
# ELASTICSEARCH
# ================================
# Use http://elasticsearch:9200 when running via docker-compose
# Use http://localhost:9200 for local development
ES_URL=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=legal_rag_2024
ES_INDEX=legal_rag

# ================================
# RETRIEVAL CONFIG
# ================================
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K_RETRIEVE=50
TOP_K_RERANK=8

# ================================
# API CONFIG
# ================================
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3001

# ================================
# OPTIONAL: CourtListener
# Only needed to re-download case law PDFs
# ================================
COURTLISTENER_TOKEN=your_token_here
